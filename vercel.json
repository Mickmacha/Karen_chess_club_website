{
  "version": 2,
  "projects": {
    "nextjs-kcc_site": {
      "name": "nextjs-kcc_site",
      "root": "nextjs-kcc_site",  
      "output": ".next"
    },
    "studio-kcc_site": {
      "name": "studio-kcc_site",
      "root": "studio-kcc_site",   
      "output": "dist"
    }
  },
  "routes": [
    {
      "src": "/studio/(.*)",
      "dest": "/studio-kcc_site/$1" 
    },
    {
      "src": "/(.*)",
      "dest": "/nextjs-kcc_site/$1"  
    }
  ]
}