{
  "version": 2,
  "routes": [
    {
      "src": "/studio/(.*)",
      "dest": "/studio-kcc_site/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/nextjs-kcc_site/$1"
    }
  ],
  "projects": {
    "nextjs-kcc_site": {
      "root": "nextjs-kcc_site",
      "ouput": ".next"
    },
    "studio-kcc_site": {
      "root": "studio-kcc_site",
      "output": "dist"
    }
  }
}